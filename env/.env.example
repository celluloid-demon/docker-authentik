
###############################
#                             #
#          Authentik          #
#                             #
###############################

# Docker-compose settings
COMPOSE_FILE='docker-compose.yml:features/ports.yml:passwords/secret.yml'
COMPOSE_PATH_SEPARATOR=':'
COMPOSE_REMOVE_ORPHANS=true

# Convenience variables
BIND_MOUNTS="${HOME}/.docker.bind-mounts/authentik"
SECRETS="${HOME}/.docker.secrets/authentik"

# =========================== Authentik Settings ==============================

PG_IMAGE='docker.io/library/postgres'
PG_TAG='16-alpine'

AUTHENTIK_IMAGE='ghcr.io/goauthentik/server'
AUTHENTIK_TAG='2026.2.2'

COMPOSE_PORT_HTTP=9000
COMPOSE_PORT_HTTPS=9443

DATABASE='database'
DATA="${BIND_MOUNTS}/data"
CERTS="${BIND_MOUNTS}/certs"
CUSTOM_TEMPLATES="${BIND_MOUNTS}/custom-templates"

# ============================= Email Settings ================================

# SMTP Host Emails are sent to
AUTHENTIK_EMAIL__HOST='smtp.protonmail.ch'
AUTHENTIK_EMAIL__PORT=587

# Optionally authenticate (don't add quotation marks to your password)
AUTHENTIK_EMAIL__USERNAME='gandalf@gmail.com'
AUTHENTIK_EMAIL__PASSWORD=file:///run/secrets/authentik_email_password

# Use StartTLS
AUTHENTIK_EMAIL__USE_TLS=true

# Use SSL
AUTHENTIK_EMAIL__USE_SSL=false
AUTHENTIK_EMAIL__TIMEOUT=10

# Email address authentik will send from, should have a correct @domain
AUTHENTIK_EMAIL__FROM='gandalf@gmail.com'
